# API
API_PORT=3000
API_GLOBAL_PREFIX=api
NODE_ENV=development

# CORS / Frontend
WEB_ORIGIN=http://localhost:4200

# Sessão / Cookies
SESSION_COOKIE_NAME=__session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_MAX_AGE_DAYS=5
CSRF_COOKIE_NAME=XSRF-TOKEN

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app
DB_NAME=agendarhorario
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Redis (filas BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Firebase Admin
# Use uma das duas opções abaixo:
# 1) Caminho para o JSON do service account (recomendado em dev):
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
# 2) Conteúdo do JSON inline (recomendado em prod via Secret Manager):
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase Identity Toolkit (login via senha pelo backend)
FIREBASE_PROJECT_ID=
FIREBASE_WEB_API_KEY=

# Email - SendGrid
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@agendarhorario.com

# Em dev, fallback para MailHog SMTP (sem SendGrid)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USE_FOR=dev # dev | never

# Twilio (SMS + WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Throttle
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
